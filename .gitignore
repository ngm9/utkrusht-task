# =========================
# Utkrushta Task - .gitignore
# =========================

# ----- Project-specific -----
# 2026-05-25 layout migration: outputs that were under infra_assets/ moved to
# data/generated/task_artifacts/. Local task artifacts and PR-review artifact
# trees remain untracked; agent-generated prompts and committed scenarios stay
# tracked (they're effectively the prompt + scenario corpus until B4 moves
# them to Postgres).
data/generated/task_artifacts/
data/generated/pr_review_tasks/
temp_deploy_*/
export/
flows/non_tech/test_assets/
agent_task_creator.log

# ----- Environment & Secrets -----
.env
.env.*
.env.local
.env.production
.env.development

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
.venv/
venv/
env/
.Python

# ----- IDE & Editors -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Claude Code -----
.claude/
.claude.json

# ----- Local agent / tooling caches -----
.illuminate/
.reflect/
.fastembed_cache/
.task_agent_runs/
prompt_generator/compiled/

# ----- Secrets / tokens -----
.google_token.json

# ----- Logs -----
*.log

# ----- OS -----
desktop.ini
