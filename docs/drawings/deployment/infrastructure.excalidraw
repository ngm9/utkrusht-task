    {
      "id": "tom_wins", "type": "text",
      "x": 900, "y": 455, "width": 820, "height": 200, "angle": 0,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 702, "version": 1, "versionNonce": 1,
      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "text": "•  Cold start 25–35s  (vs 60–90s droplet)\n•  Per-second billing — idle costs nothing\n•  No AVAILABLE_IPS, no human cleanup\n•  Atomic teardown — sb.kill() removes the whole VM\n•  Heterogeneous stacks survive (DinD, k3d, Compose, Java/Spring, Mongo, Redis)\n\nVendor escape valve: e2b-dev/infra is Apache-2 self-hostable.",
      "fontSize": 15, "fontFamily": 5,
      "textAlign": "left", "verticalAlign": "top", "baseline": 13,
      "containerId": null,
      "originalText": "•  Cold start 25–35s  (vs 60–90s droplet)\n•  Per-second billing — idle costs nothing\n•  No AVAILABLE_IPS, no human cleanup\n•  Atomic teardown — sb.kill() removes the whole VM\n•  Heterogeneous stacks survive (DinD, k3d, Compose, Java/Spring, Mongo, Redis)\n\nVendor escape valve: e2b-dev/infra is Apache-2 self-hostable.",
      "lineHeight": 1.4, "autoResize": true
    },

