      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "text": "The pain — abandoned tasks become stale droplets",
      "fontSize": 18, "fontFamily": 5,
      "textAlign": "left", "verticalAlign": "top", "baseline": 14,
      "containerId": null,
      "originalText": "The pain — abandoned tasks become stale droplets",
      "lineHeight": 1.25, "autoResize": true
    },
    {
      "id": "today_pain", "type": "text",
      "x": 80, "y": 435, "width": 720, "height": 200, "angle": 0,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "roundness": null, "seed": 402, "version": 1, "versionNonce": 1,
      "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "text": "1.  Candidate closes laptop / loses network mid-test\n2.  kill.sh never fires → containers + /root/task linger\n3.  Next deploy sees the droplet as 'occupied' and skips it\n4.  Pool fills up → engineer SSHes in and cleans up by hand\n\nCold start on a clean droplet: 60–90s.\nNo single answer to 'what is running where right now?'",
      "fontSize": 15, "fontFamily": 5,
      "textAlign": "left", "verticalAlign": "top", "baseline": 13,
      "containerId": null,
      "originalText": "1.  Candidate closes laptop / loses network mid-test\n2.  kill.sh never fires → containers + /root/task linger\n3.  Next deploy sees the droplet as 'occupied' and skips it\n4.  Pool fills up → engineer SSHes in and cleans up by hand\n\nCold start on a clean droplet: 60–90s.\nNo single answer to 'what is running where right now?'",
      "lineHeight": 1.4, "autoResize": true
    },

