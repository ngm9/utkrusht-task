      "boundElements": null,
      "updated": 1717000000000,
      "link": null,
      "locked": false,
      "text": "Legend\n\nBlue   = input data\nYellow = LLM step (only on first encounter)\nGray   = Supabase / registry\nGreen  = TaskRuntime / sandbox\nOrange = consumer of TaskRuntime\n\nDashed arrow = MISS path (rare)",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Legend\n\nBlue   = input data\nYellow = LLM step (only on first encounter)\nGray   = Supabase / registry\nGreen  = TaskRuntime / sandbox\nOrange = consumer of TaskRuntime\n\nDashed arrow = MISS path (rare)",
      "lineHeight": 1.25,
      "baseline": 14
    }
